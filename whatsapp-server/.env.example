# 1. Get these from your Supabase Project Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 2. Go to your Supabase `profiles` table and copy your specific UUID here.
# This ensures the Baileys server fetches the correct AI rules for your account.
TARGET_USER_ID=your-uuid-here

# 3. Port for the keep-alive server
PORT=3000
